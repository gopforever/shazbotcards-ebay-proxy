# eBay API Credentials
EBAY_APP_ID=your-app-id-here
EBAY_DEV_ID=your-dev-id-here
EBAY_CERT_ID=your-cert-id-here
EBAY_RU_NAME=your-ru-name-here

# Frontend URL (for CORS) – kept for backwards-compatibility, merged into ALLOWED_ORIGINS
FRONTEND_URL=https://projectebay.netlify.app

# Comma-separated list of additional allowed origins (optional).
# The Netlify frontend and localhost dev origins are always included by default.
# Example: ALLOWED_ORIGINS=https://my-other-site.com,https://staging.netlify.app
ALLOWED_ORIGINS=

# Server
PORT=3000
NODE_ENV=production
